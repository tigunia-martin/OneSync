# Build artefacts
**/bin/
**/obj/
src/OneSync.Installer/stage/
src/OneSync.Installer/OneSync.msi
src/OneSync.Installer/OneSync.wixpdb
src/OneSync.ShellOverlay/x64/
src/OneSync.ShellOverlay/.vs/

# Disposable output folders
publish/
dist/
stage/

# Visual Studio noise
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Deployment configs — never commit real tenant values. The template at
# src/OneSync/config.template.json is the canonical shape that's safe to
# commit; the repo's config.json has all-zero placeholder GUIDs.
deploy/
*.local.json
config.*.json
!config.template.json
!src/OneSync/config.json

# Logs
*.log
src/**/*.log

# Local backups (rollback snapshots, in-progress refactor copies)
backups/
*.bak
*.bak-*

# Runtime state (LiteDB files etc.)
*.db
*.db-log

# OS / editor noise
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/
.idea/

# Test output / coverage
TestResults/
coverage/
*.coverage
*.coveragexml

# Local working files (notes, drafts, dev assets)
BACKLOG.md
Icon.png
docs/superpowers/
docs/measurements/
linkedin-post.txt
reddit-post-*.txt
reddit-strategy.txt

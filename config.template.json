{
  // ====================================================================
  // OneSync configuration REFERENCE
  // ====================================================================
  //
  // This file is a REFERENCE, not the file you edit on a deployed
  // machine. The installer ships a minimal `config.json` with placeholder
  // GUIDs at `C:\Program Files\OneSync\config.json` — edit THAT file
  // in place. Just fill in `tenantId`, `clientId`, `authority`, and your
  // drive list; every other setting has a sensible default and only
  // needs to appear in your real config if you want to override it.
  //
  // Consult this template when you want to look up:
  //   - What a particular setting does
  //   - Its default value and acceptable range
  //   - Whether it's safe to leave out
  //
  // The OneSync JSON loader accepts // line comments and trailing commas,
  // so you can copy snippets from here into your real config without
  // stripping the comments first.
  //
  // The minimal viable config is about 15 lines:
  //
  //   {
  //     "tenantId":  "<your tenant GUID>",
  //     "clientId":  "<your app registration client ID>",
  //     "authority": "https://login.microsoftonline.com/<your tenant GUID>",
  //     "drives": [
  //       { "letter": "H", "label": "Home", "type": "onedrive", "remotePath": "/" }
  //     ]
  //   }
  // ====================================================================

  // The Microsoft 365 tenant GUID you're syncing against.
  // Find it in Entra admin centre → Overview → Tenant ID.
  "tenantId": "00000000-0000-0000-0000-000000000000",

  // The Application (client) ID of an Entra app registration with these
  // *delegated* permissions:
  //   Files.ReadWrite       (read/write the user's OneDrive)
  //   Sites.ReadWrite.All   (read/write SharePoint document libraries)
  //   offline_access        (refresh tokens for silent SSO)
  //   User.Read             (basic profile)
  // The app registration must allow public client flows.
  "clientId": "00000000-0000-0000-0000-000000000000",

  // The MSAL authority. For most tenants this is just the URL below with
  // your tenant ID substituted. Leave the placeholder if you set tenantId.
  "authority": "https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000",

  // Where OneSync stores its local NTFS-backed drive folders, sync queue
  // DB, metadata DB, and logs. %LOCALAPPDATA% is per-user — change to
  // %PROGRAMDATA% for shared-machine deployments where logoff cleanup
  // should NOT happen per user.
  "localStorageRoot": "%LOCALAPPDATA%\\OneSync\\Drives",

  // ====================================================================
  // Drives — list every OneDrive / SharePoint library you want exposed
  // as a Windows drive letter. Comment out or remove drives you don't
  // want; OneSync will still skip drives the signed-in user has no
  // permission for (controlled by driveFiltering below).
  // ====================================================================
  "drives": [
    {
      "letter": "H",                       // Windows drive letter
      "label": "Home Folder",              // Display label in Explorer
      "type": "onedrive",                  // "onedrive" | "sharepoint"
      "remotePath": "/",                   // Subpath of the drive (usually "/")
      "syncMode": "bidirectional",
      "priority": 1,                       // Lower = higher priority (used by upload scheduling)
      // Windows shell folders to redirect to this drive (only valid for
      // OneDrive home drives — SharePoint libraries skip this). Each entry
      // creates and points the corresponding User Shell Folder at the
      // drive. Leave empty array if you don't want folder redirection.
      "folderRedirection": [
        "Desktop",
        "Documents",
        "Downloads",
        "Music",
        "Pictures",
        "Videos"
      ]
    },

    // Example SharePoint library — REPLACE siteUrl with your real site.
    // Remove this entry entirely if you don't have shared SharePoint
    // libraries to expose.
    // {
    //   "letter": "I",
    //   "label": "Student Shared Area",
    //   "type": "sharepoint",
    //   "siteUrl": "https://YOUR-TENANT.sharepoint.com/sites/YOUR-SITE",
    //   "libraryName": "Shared Documents",
    //   "remotePath": "/",
    //   "syncMode": "bidirectional",
    //   "priority": 2
    // },

    // Example second SharePoint library.
    // {
    //   "letter": "J",
    //   "label": "Staff Shared Area",
    //   "type": "sharepoint",
    //   "siteUrl": "https://YOUR-TENANT.sharepoint.com/sites/ANOTHER-SITE",
    //   "libraryName": "Shared Documents",
    //   "remotePath": "/",
    //   "syncMode": "bidirectional",
    //   "priority": 3
    // }
  ],

  // ====================================================================
  // Drive filtering — at startup, OneSync probes each drive in `drives`
  // via Graph. Drives the user has no access to are skipped silently
  // (so a single config.json works for staff + students alike).
  // ====================================================================
  "driveFiltering": {
    "enabled": true,
    "checkPermissionsAtStartup": true,
    "skipDriveOn403": true,
    "logSkippedDrives": true
  },

  // ====================================================================
  // Logoff / logon cleanup — for shared machines, wipe local sync state
  // at logoff so the next user starts clean. Auth cache + metadata DB
  // are preserved so the next logon can re-establish sync quickly.
  // For single-user machines, set both to false to keep files cached
  // across sessions.
  // ====================================================================
  "cleanup": {
    "cleanOnLogoff": true,
    "cleanOnLogon": true,
    "cleanupDelayAfterSyncFlushSeconds": 5,
    "preserveAuthCache": true,
    "preserveLogs": true,
    "preserveQuotaCache": true
  },

  // ====================================================================
  // Sync engine tuning. Defaults are sensible for a school of 1000-2000
  // users on a normal broadband line; reduce maxConcurrentUploads /
  // maxConcurrentGraphRequests if you're on a constrained network.
  // ====================================================================
  "syncSettings": {
    "pollIntervalSeconds": 300,                  // Delta poll cadence
    "maxConcurrentUploads": 3,
    "maxConcurrentHydrations": 4,
    "maxConcurrentGraphRequests": 8,
    "shutdownTimeoutSeconds": 90,                // Max time to flush pending uploads at logoff
    "maxFileSizeMB": 250,                        // Files larger than this aren't synced
    "excludePatterns": [
      "*.tmp",
      "*.~tmp",
      "~$*",
      "Thumbs.db",
      "desktop.ini",
      ".ds_store",
      "*.lnk",
      "*.crdownload",
      "*.part",
      "*.partial",
      "*.crswap",
      "*.swp",
      "*.swo",
      "*.lock",
      "*.lck",
      "~*.tmp",
      "__autosave_*",
      "WRL*.tmp",
      "*.bak.tmp"
    ],
    "quotaRefreshIntervalSeconds": 300,
    "deltaQueryIntervalSeconds": 300,
    "uploadDebounceMs": 2000,
    "maxRetries": 5,
    "retryBackoffBaseSeconds": 30,
    "maxRetryAfterSeconds": 600,
    // Client-side rate limit — preempt Graph 429s by self-throttling below the
    // ~2000 req/min per-app-per-tenant cap. Set "enabled": false to disable.
    "graphRateLimit": {
      "enabled": true,
      "requestsPerSecond": 30,
      "burstSize": 60,
      "waitWarnThresholdMs": 1000
    },

    // ----- LRU local-disk eviction -----
    // Truncates least-recently-used hydrated files back to 0-byte
    // placeholders when local disk falls below threshold. The cloud
    // copy is NEVER touched — eviction is purely local.
    "evictionEnabled": true,
    "evictionFreeSpaceThresholdGB": 2,            // Start evicting below this
    "evictionTargetFreeSpaceGB": 4,               // Stop once we have this much free
    "evictionCheckIntervalSeconds": 60,
    "evictionMinAgeMinutes": 15                   // Don't evict files accessed in this window
  },

  // ====================================================================
  // Logging. Logs go to <path>\onesync-YYYYMMDD.log; older files
  // are rolled up to maxFiles. Level can be Information (default),
  // Debug (verbose), or Warning.
  // ====================================================================
  "logging": {
    "level": "Information",
    "path": "%LOCALAPPDATA%\\OneSync\\Logs",
    "maxSizeMB": 50,
    "maxFiles": 10
  },

  // Note: an experimental cross-machine cooperative-polling layer exists
  // in the binary but is intentionally undocumented here. The default
  // single-machine defences (client-side token bucket, ?token=latest
  // bootstrap, lazy folder enumeration, 429 cooldown awareness) keep
  // Graph load comfortably under tenant throttling thresholds for
  // realistic estate sizes, so the cooperation layer adds complexity
  // without a corresponding benefit for most deployments.
}
